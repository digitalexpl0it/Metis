#!/usr/bin/env bash
# Metis standalone session launcher (Stage C.5).
#
# This is the entry point a login manager (GDM, SDDM, greetd, …) runs when you
# pick "Metis" from the session list — analogous to Hyprland's `Hyprland`
# session wrapper. The display manager has already given us our own VT and a
# logind seat, so libseat can take DRM master cleanly; on exit we drop straight
# back to the greeter.
#
# It sets the desktop identity, pins the DRM backend, exports the session
# environment to the user D-Bus / systemd activation environment (so portals and
# activated apps land in this session), then execs the compositor.

set -uo pipefail

# --- desktop identity -------------------------------------------------------
# Keep "Metis" first so the Metis xdg-desktop-portal backend (UseIn=Metis) and
# its preferred-portals config still win. The trailing ":GNOME" is purely so
# Chromium/Electron apps (Cursor, GitHub Desktop, browsers) auto-detect the
# gnome-libsecret credential backend instead of falling back to plaintext
# ("encryption is low"). No Metis code keys off this value.
export XDG_CURRENT_DESKTOP="Metis:GNOME"
export XDG_SESSION_DESKTOP="metis"
export XDG_SESSION_TYPE="wayland"

# --- backend ---------------------------------------------------------------
# Pin the standalone DRM/KMS backend regardless of autodetection.
export METIS_BACKEND="drm"

# --- Flatpak app visibility -------------------------------------------------
# Flatpak installs export their `.desktop` entries and icons under dedicated
# `exports/share` trees, NOT the system applications dir. GIO (and therefore the
# Metis launcher and running-apps dock, which enumerate via `gio::AppInfo`) only
# see them when those trees are on XDG_DATA_DIRS. Most distros add these via
# `/etc/profile.d/flatpak.sh`, but a login-manager session frequently does not
# source profile scripts, so Flatpak apps silently go missing. Ensure the export
# dirs are present here (harmless when Flatpak is absent — the dirs just will not
# exist). XDG_DATA_DIRS is already forwarded to the activation environment below.
metis_add_data_dir() {
    local dir="$1"
    case ":${XDG_DATA_DIRS:-}:" in
        *":$dir:"*) : ;; # already present — keep the existing ordering
        *) XDG_DATA_DIRS="${XDG_DATA_DIRS:+$XDG_DATA_DIRS:}$dir" ;;
    esac
}
# Seed the freedesktop default if the login stack left it unset.
export XDG_DATA_DIRS="${XDG_DATA_HOME:-$HOME/.local/share}:/usr/local/share:/usr/share"
metis_add_data_dir "${XDG_DATA_HOME:-$HOME/.local/share}/flatpak/exports/share"
metis_add_data_dir "/var/lib/flatpak/exports/share"
metis_add_data_dir "/var/lib/snapd/desktop"
export XDG_DATA_DIRS

# GTK shell: prefer the Wayland backend.
export GDK_BACKEND="${GDK_BACKEND:-wayland}"
# Some GPU/driver combos hang GTK's GL renderer under a fresh compositor; the
# Cairo renderer is a safe default for Metis shell. Override via
# METIS_SHELL_GSK_RENDERER (or GSK_RENDERER) before launch if GL is reliable.
export METIS_SHELL_GSK_RENDERER="${METIS_SHELL_GSK_RENDERER:-${GSK_RENDERER:-cairo}}"
export GSK_RENDERER="${GSK_RENDERER:-$METIS_SHELL_GSK_RENDERER}"

# --- Electron / Chromium: prefer native Wayland ----------------------------
# Metis is a Wayland compositor; its XWayland path is a fallback. Electron/Ozone
# apps default to XWayland unless hinted otherwise, and their XWayland map/unmap
# lifecycle is flaky under nested/self-managed WMs (observed: Claude Desktop's
# window juggling ends in a clean `window-all-closed` quit — it opens and
# immediately closes). Native Wayland is stable and avoids the XWayland round
# trip entirely, so we opt apps into it:
#   * ELECTRON_OZONE_PLATFORM_HINT=auto — the standard switch most Electron apps
#     (Cursor, VS Code, Discord, Signal, …) honor to pick Wayland when present.
#   * CLAUDE_USE_WAYLAND=1 — Claude Desktop's launcher force-passes
#     `--ozone-platform=x11` and only respects native Wayland via this opt-in.
# Both are overridable so a user can force XWayland per-app if a specific app
# renders better there.
export ELECTRON_OZONE_PLATFORM_HINT="${ELECTRON_OZONE_PLATFORM_HINT:-auto}"
export CLAUDE_USE_WAYLAND="${CLAUDE_USE_WAYLAND:-1}"

# --- GTK startup hardening for a standalone (non-GNOME) session ------------
# Metis serves org.freedesktop.portal.Settings via metis-portal (started by the
# compositor). The AT-SPI accessibility bus is still disabled — GTK connects to
# org.a11y.Bus at startup and can hang when no bus exists in a bare session.
export GTK_A11Y="${GTK_A11Y:-none}"
export NO_AT_BRIDGE="${NO_AT_BRIDGE:-1}"

# Default logging if the session leaves it unset.
export RUST_LOG="${RUST_LOG:-metis_shell=debug,metis_compositor=info,warn}"

# --- secret service / keyring ----------------------------------------------
# Metis is only a *client* of the freedesktop Secret Service (via oo7); a bare
# session ships no provider, so keyring-backed apps (Cursor, GitHub Desktop,
# browsers) fall back to plaintext ("encryption is low"). Everything here speaks
# the standard `org.freedesktop.secrets` D-Bus API, so ANY provider works — we
# just make sure one is running, preferring whatever is installed.
#
# Note: without PAM auto-unlock (pam_gnome_keyring) the login keyring starts
# locked; the first secret access pops gcr's prompter once per session — install
# `gcr4` so that dialog can appear under Metis.
ks_log() { echo "metis-session: keyring: $*" >&2; }

# True if org.freedesktop.secrets is already owned on the bus or is D-Bus
# activatable (provider auto-starts on first access — nothing to launch).
metis_have_secret_service() {
    if command -v busctl >/dev/null 2>&1 \
        && busctl --user status org.freedesktop.secrets >/dev/null 2>&1; then
        return 0
    fi
    if command -v gdbus >/dev/null 2>&1 \
        && gdbus call --session --dest org.freedesktop.DBus \
            --object-path /org/freedesktop/DBus \
            --method org.freedesktop.DBus.NameHasOwner org.freedesktop.secrets \
            2>/dev/null | grep -q true; then
        return 0
    fi
    local dir
    local IFS=:
    for dir in /usr/local/share /usr/share ${XDG_DATA_DIRS:-}; do
        [ -e "$dir/dbus-1/services/org.freedesktop.secrets.service" ] && return 0
    done
    return 1
}

# Start the best available Secret Service provider, in preference order.
metis_start_secret_service() {
    if metis_have_secret_service; then
        ks_log "org.freedesktop.secrets already available"
        return 0
    fi
    if command -v gnome-keyring-daemon >/dev/null 2>&1; then
        eval "$(gnome-keyring-daemon --start --components=secrets,ssh 2>/dev/null)"
        export SSH_AUTH_SOCK
        ks_log "started gnome-keyring-daemon (secrets + ssh-agent)"
    elif command -v kwalletd6 >/dev/null 2>&1; then
        kwalletd6 >/dev/null 2>&1 &
        ks_log "started kwalletd6 (KWallet Secret Service)"
    elif command -v kwalletd5 >/dev/null 2>&1; then
        kwalletd5 >/dev/null 2>&1 &
        ks_log "started kwalletd5 (KWallet Secret Service)"
    elif command -v keepassxc >/dev/null 2>&1; then
        keepassxc >/dev/null 2>&1 &
        ks_log "started KeePassXC (enable Secret Service integration in its settings)"
    elif command -v pass-secret-service >/dev/null 2>&1; then
        pass-secret-service >/dev/null 2>&1 &
        ks_log "started pass-secret-service"
    else
        ks_log "WARNING: no Secret Service provider found — keyring-backed apps will"
        ks_log "         fall back to plaintext. Install one (recommended: gnome-keyring)."
    fi
}
metis_start_secret_service

# --- remote desktop autostart (Phase 7) ------------------------------------
# Best-effort: when remote.json has enabled + auto_start, start headless RDP.
# Skipped in nested/dev sessions unless METIS_BACKEND=drm (real login session).
metis_remote_autostart() {
    if [[ "${METIS_BACKEND:-}" != "drm" ]]; then
        return 0
    fi
    if ! command -v metis-remote >/dev/null 2>&1; then
        return 0
    fi
    metis-remote autostart 2>/dev/null || true
}
metis_remote_autostart

# --- session log -----------------------------------------------------------
# A login-manager session has no terminal, so capture compositor + shell output
# to a file (the shell inherits these fds). Read it after a failed run:
#   ~/.local/state/metis/logs/session-latest.log
LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/metis/logs"
mkdir -p "$LOG_DIR" 2>/dev/null || true
SESSION_LOG="$LOG_DIR/session-$(date +%Y%m%d-%H%M%S).log"
ln -sfn "$SESSION_LOG" "$LOG_DIR/session-latest.log" 2>/dev/null || true

# --- locate the compositor -------------------------------------------------
# Installed layout puts metis-compositor + metis-shell side by side; the
# compositor resolves metis-shell next to itself. Fall back to PATH.
SELF_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
if [[ -x "$SELF_DIR/metis-compositor" ]]; then
    COMP_BIN="$SELF_DIR/metis-compositor"
else
    COMP_BIN="$(command -v metis-compositor || true)"
fi
if [[ -z "${COMP_BIN:-}" ]]; then
    echo "metis-session: metis-compositor not found in $SELF_DIR or PATH" >&2
    exit 127
fi

# --- activation environment ------------------------------------------------
# Hand our session env to systemd --user and D-Bus so portals / activated apps
# run inside Metis. Best-effort: a session may not have a user bus yet.
SESSION_VARS=(
    WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP XDG_SESSION_TYPE
    XDG_SESSION_ID DISPLAY GDK_BACKEND METIS_SHELL_GSK_RENDERER GTK_A11Y NO_AT_BRIDGE
    SSH_AUTH_SOCK XDG_DATA_DIRS XDG_CONFIG_DIRS
    ELECTRON_OZONE_PLATFORM_HINT CLAUDE_USE_WAYLAND
)
if command -v dbus-update-activation-environment >/dev/null 2>&1; then
    dbus-update-activation-environment --systemd "${SESSION_VARS[@]}" 2>/dev/null || true
elif command -v systemctl >/dev/null 2>&1; then
    systemctl --user import-environment "${SESSION_VARS[@]}" 2>/dev/null || true
fi

exec "$COMP_BIN" "$@" >"$SESSION_LOG" 2>&1
